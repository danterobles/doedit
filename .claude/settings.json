{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | { read -r f; case \"$f\" in *.swift) swift build ;; esac; }",
            "timeout": 120,
            "statusMessage": "Building..."
          }
        ]
      }
    ]
  }
}
