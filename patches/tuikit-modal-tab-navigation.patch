@@ -97,10 +97,18 @@ extension AlertPresentationModifier: Renderable {
         // Register an alert focus section and activate it.
         // The alert section becomes the active section, so Tab/arrows
         // only navigate within the alert's focusable elements (buttons).
+        //
+        // Only call activateSection when the alert first appears. On subsequent
+        // render passes the section is already active (activeSectionID is preserved
+        // through beginRenderPass), so calling activateSection would reset focusedID
+        // to nil and undo any Tab navigation the user performed within the alert.
         let sectionID = Self.alertSectionID
         if !context.isMeasuring {
+            let wasAlreadyActive = focusManager.isActiveSection(sectionID)
             focusManager.registerSection(id: sectionID)
-            focusManager.activateSection(id: sectionID)
+            if !wasAlreadyActive {
+                focusManager.activateSection(id: sectionID)
+            }
         }

